def extract_shape(ascii_grid, row_start, col_start):
    """Extract the black pixel pattern from a 7x7 character"""
    shape = []
    for r in range(row_start, row_start + 7):
        row = ascii_grid[r][col_start:col_start+7]
        # Extract B positions
        shape_row = tuple(1 if c == 'B' else 0 for c in row)
        shape.append(shape_row)
    return tuple(shape)

