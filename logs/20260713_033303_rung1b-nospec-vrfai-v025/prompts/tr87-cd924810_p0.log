# Categorize B (black) objects by region using boundary coordinates
seg = current_frame.segmentation
nodes = seg['nodes']

b_objects = [n for n in nodes if n['color'] == 'B']

# Categorize by row position
upper_grid = []  # rows 4-28
sky_bar = []      # rows 40-46
pink_bar = []     # rows 51-57

for n in b_objects:
    # Get average row from boundary
    rows = [p[0] for p in n['boundary']]
    avg_row = sum(rows) / len(rows)
    if avg_row < 30:
        upper_grid.append(n)
    elif avg_row < 50:
        sky_bar.append(n)
    else:
        pink_bar.append(n)

print(f"Upper grid symbols: {len(upper_grid)}")
print(f"Sky blue bar symbols: {len(sky_bar)}")
print(f"Pink bar symbols: {len(pink_bar)}")

# Sort each group by column position
def avg_col(n):
    cols = [p[1] for p in n['boundary']]
    return sum(cols) / len(cols)

upper_grid.sort(key=avg_col)
sky_bar.sort(key=avg_col)
pink_bar.sort(key=avg_col)

# Print hashes for each group
print("\nUpper grid symbol hashes (sorted by col):")
for i, n in enumerate(upper_grid):
    print(f"  pos {i}: hash={n['hash']}, pixels={n['pixels']}")

