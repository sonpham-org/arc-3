# Normalize: find bounding box and extract minimal pattern
def normalize(pat):
    rows = list(pat)
    # Find min/max row with any 1
    rmin = rmax = cmin = cmax = None
    for ri, row in enumerate(rows):
        for ci, c in enumerate(row):
            if c == '1':
                if rmin is None: rmin = ri
                rmax = ri
                if cmin is None: cmin = ci
                cmax = ci
    if rmin is None: return tuple()
    return tuple(row[cmin:cmax+1] for row in rows[rmin:rmax+1])

