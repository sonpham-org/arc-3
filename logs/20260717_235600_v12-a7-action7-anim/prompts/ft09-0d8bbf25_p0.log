ascii_lines = current_frame.ascii.split('\n')

# Cell centers based on boundaries
row_starts = [4, 12, 20, 28, 36, 44, 52]
col_starts = [12, 20, 28, 36, 44]

def sample_cell_center(r_idx, c_idx):
    r = row_starts[r_idx] + 3
    c = col_starts[c_idx] + 3
    return ascii_lines[r][c:c+2]

def sample_cell_region(r_idx, c_idx):
    r_start = row_starts[r_idx]
    c_start = col_starts[c_idx]
    region = []
    for dr in range(6):
        row_str = ascii_lines[r_start + dr][c_start:c_start+6]
        region.append(row_str)
    return region

print("Grid colors (center sample):")
for ri in range(7):
    row_colors = []
    for ci in range(5):
        color = sample_cell_center(ri, ci)
        row_colors.append(color)
    print(f"  Row {ri}: {row_colors}")

print("\nSpecial cell regions:")
# Find cells that are not solid red
for ri in range(7):
    for ci in range(5):
        center = sample_cell_center(ri, ci)
        if center != 'RR':
            print(f"\nCell ({ri},{ci}):")
