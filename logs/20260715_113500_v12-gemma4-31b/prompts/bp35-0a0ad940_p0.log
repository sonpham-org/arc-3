import collections

def summarize_segmentation(segmentation):
    nodes = segmentation['nodes']
    summary = collections.defaultdict(list)
    for node in nodes:
        summary[node['color']].append({
            'id': node['id'],
            'pixels': node['pixels'],
            'boundary': node['boundary'],
            'hash': node['hash']
        })
    return summary

seg_summary = summarize_segmentation(current_frame.segmentation)
print(f"Colors found: {list(seg_summary.keys())}")
for color, objects in seg_summary.items():
    print(f"Color {color}: {len(objects)} objects")

print(f"Valid actions: {valid_actions}")
print(f"Level: {current_frame.level}, Step: {current_frame.step}")
print(f"Shape: {current_frame.shape}")

# Find player (usually blue/yellow)
player_nodes = [n for n in current_frame.segmentation['nodes'] if n['color'] in ['b', 'Y']]
print(f"Player nodes: {player_nodes}")
