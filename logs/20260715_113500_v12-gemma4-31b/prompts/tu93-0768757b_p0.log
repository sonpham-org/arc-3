import collections

def solve():
    board = current_frame.ascii.split('\n')
    rows = len(board)
    cols = len(board[0]) if rows > 0 else 0
    
    start_pos = None
    goal_pos = None
    grid = []
    for r in range(rows):
        row_cells = []
        for c in range(cols):
            char = board[r][c]
            row_cells.append(char)
            if char in ['S', 'b']:
                start_pos = (r, c)
            elif char == 'N':
                goal_pos = (r, c)
        grid.append(row_cells)
    
    # If start_pos is not found by char, use segmentation
    if start_pos is None:
        nodes = current_frame.segmentation['nodes']
        start_node = next((n for n in nodes if n['color'] in ['S', 'b']), None)
        if start_node:
            # Use the top-left corner of the boundary
            start_pos = tuple(start_node['boundary'][0])
            
    if goal_pos is None:
        nodes = current_frame.segmentation['nodes']
        goal_node = next((n for n in nodes if n['color'] == 'N'), None)
        if goal_node:
            goal_pos = tuple(goal_node['boundary'][0])

    print(f"Start: {start_pos}, Goal: {goal_pos}")
    
    if not start_pos or not goal_pos:
        return None
    
    queue = collections.deque([(start_pos, [])])
    visited = {start_pos}
    
    while queue:
        (r, c), path = queue.popleft()
        if (r, c) == goal_pos:
            return path
        
        for dr, dc, action in [(-1, 0, 'UP'), (1, 0, 'DOWN'), (0, -1, 'LEFT'), (0, 1, 'RIGHT')]:
            nr, nc = r + dr, c + dc
            if 0 <= nr < rows and 0 <= nc < cols:
                # Walkable: 'w', 'S', 'b', 'N'
                if grid[nr][nc] in ['w', 'S', 'b', 'N'] and (nr, nc) not in visited:
                    visited.add((nr, nc))
                    queue.append(((nr, nc), path + [action]))
    
    return None

path = solve()
if path:
    print(f"Path found: {path}")
    # Try to execute a small part of the path first to see if the game is actually over
    # Or just try the whole thing.
    action(path)
else:
    print("No path found")
