    cols = len(board[0]) if rows > 0 else 0
    
    start_pixels = set()
    goal_pixels = set()
    walkable = set()
    
    for r in range(rows):
        for c in range(cols):
            char = board[r][c]
            if char in ['S', 'b']:
                start_pixels.add((r, c))
                walkable.add((r, c))
            elif char == 'N':
                goal_pixels.add((r, c))
                walkable.add((r, c))
            elif char == 'w':
                walkable.add((r, c))
    
    if not start_pixels or not goal_pixels:
        print("Start or goal pixels not found")
        return None
    
    # BFS from any start pixel to any goal pixel
    queue = collections.deque([(p, []) for p in start_pixels])
    visited = set(start_pixels)
    
