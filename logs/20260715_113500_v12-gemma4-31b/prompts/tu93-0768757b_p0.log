    # Let's go back to ASCII and find all characters that are NOT black ('B')
    board = current_frame.ascii.split('\n')
    rows = len(board)
    cols = len(board[0]) if rows > 0 else 0
    
    walkable = set()
    start_pixels = set()
    goal_pixels = set()
    
    for r in range(rows):
        for c in range(cols):
            char = board[r][c]
            if char != 'B':
                walkable.add((r, c))
                if char in ['S', 'b']:
