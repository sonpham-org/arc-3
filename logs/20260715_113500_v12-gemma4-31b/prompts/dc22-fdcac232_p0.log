def get_block_info(frame):
    blocks = []
    for node in frame.segmentation['nodes']:
        if node['color'] in ['R', 'r', 'b', 'B', 'g', 'G', 'Y', 'y']:
            boundary = node['boundary']
            rows = [p[0] for p in boundary]
            cols = [p[1] for p in boundary]
            center = [sum(rows)//len(rows), sum(cols)//len(cols)]
            blocks.append({'id': node['id'], 'color': node['color'], 'center': center, 'boundary': boundary})
    return blocks

blocks = get_block_info(current_frame)
print(f"Blocks: {blocks}")
