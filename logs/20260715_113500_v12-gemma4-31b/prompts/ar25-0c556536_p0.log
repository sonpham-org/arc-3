import collections

# Summarize the board segmentation
def summarize_segmentation(seg):
    nodes = seg['nodes']
    summary = collections.defaultdict(list)
    for node in nodes:
        summary[node['color']].append({
            'id': node['id'],
            'hash': node['hash'],
            'pixels': node['pixels'],
            'boundary': node['boundary']
        })
    return summary

