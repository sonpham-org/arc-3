def get_object_info(segmentation):
    nodes = segmentation['nodes']
    objects = []
    for node in nodes:
        rows = [p[0] for p in node['boundary']]
        cols = [p[1] for p in node['boundary']]
        center = [(min(rows) + max(rows)) // 2, (min(cols) + max(cols)) // 2]
        objects.append({
            'id': node['id'],
            'color': node['color'],
            'center': center,
            'hash': node['hash'],
            'pixels': node['pixels']
        })
    return objects

def get_symbols_by_color(objs, color_list):
    return [o for o in objs if o['color'] in color_list]

objs_now = get_object_info(current_frame.segmentation)
objs_prev = get_object_info(previous_frame.segmentation)

# Pink symbols
pink_now = get_symbols_by_color(objs_now, ['P', 'M'])
pink_prev = get_symbols_by_color(objs_prev, ['P', 'M'])

# Sort by center to identify positions
pink_now.sort(key=lambda x: (x['center'][0], x['center'][1]))
pink_prev.sort(key=lambda x: (x['center'][0], x['center'][1]))

print("Pink symbols now (sorted):")
for i, o in enumerate(pink_now):
    print(f"{i}: {o['center']} {o['hash']}")

print("\nPink symbols prev (sorted):")
for i, o in enumerate(pink_prev):
    print(f"{i}: {o['center']} {o['hash']}")

# Find which one changed
for i in range(len(pink_now)):
    if pink_now[i]['hash'] != pink_prev[i]['hash']:
        print(f"\nSymbol at index {i} changed: {pink_prev[i]['hash']} -> {pink_now[i]['hash']}")
