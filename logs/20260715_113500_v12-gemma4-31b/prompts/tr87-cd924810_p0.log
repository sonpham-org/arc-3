def get_object_info(segmentation):
    nodes = segmentation['nodes']
    objects = []
    for node in nodes:
        rows = [p[0] for p in node['boundary']]
        cols = [p[1] for p in node['boundary']]
        center = [(min(rows) + max(rows)) // 2, (min(cols) + max(cols)) // 2]
        objects.append({
            'id': node['id'],
            'color': node['color'],
            'center': center,
            'hash': node['hash'],
            'pixels': node['pixels']
        })
    return objects

def get_row_symbols(objs, color_list, row_range):
    row_objs = [o for o in objs if o['color'] in color_list and row_range[0] <= o['center'][0] <= row_range[1]]
    row_objs.sort(key=lambda x: x['center'][1])
    return [o['hash'] for o in row_objs]

objs_now = get_object_info(current_frame.segmentation)
objs_prev = get_object_info(transitions[-1].before_frame.segmentation)

