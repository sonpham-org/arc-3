def get_objects_info(segmentation):
    objects = []
    for node in segmentation['nodes']:
        # Calculate center
        center = (sum(p[0] for p in node['boundary']) // len(node['boundary']),
                   sum(p[1] for p in node['boundary']) // len(node['boundary']))
        objects.append({
            'id': node['id'],
            'hash': node['hash'],
            'color': node['color'],
            'pixels': node['pixels'],
            'center': center
        })
    return objects

objs = get_objects_info(current_frame.segmentation)
print(f"All objects: {objs}")

# Filter for the ones we care about
purple_disk = next((o for o in objs if o['color'] == 'p' and o['pixels'] > 10), None)
white_star = next((o for o in objs if o['color'] == 'W' and o['pixels'] > 5), None)
gray_star = next((o for o in objs if o['color'] in ['g', 'G'] and o['pixels'] > 5), None)
# Ring is multiple small purple nodes
ring_nodes = [o for o in objs if o['color'] == 'p' and o['pixels'] <= 5]
ring_center = (sum(o['center'][0] for o in ring_nodes) // len(ring_nodes),
               sum(o['center'][1] for o in ring_nodes) // len(ring_nodes)) if ring_nodes else None

print(f"Purple Disk: {purple_disk['center'] if purple_disk else None}")
print(f"White Star: {white_star['center'] if white_star else None}")
print(f"Gray Star: {gray_star['center'] if gray_star else None}")
print(f"Purple Ring: {ring_center}")
</parameter>
</function>
