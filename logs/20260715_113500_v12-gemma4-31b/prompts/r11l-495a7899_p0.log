def get_objects_summary(segmentation):
    summary = {}
    for node in segmentation['nodes']:
        summary[node['hash']] = {
            'color': node['color'],
            'pixels': node['pixels'],
            'center': (sum(p[0] for p in node['boundary']) // len(node['boundary']),
                       sum(p[1] for p in node['boundary']) // len(node['boundary']))
        }
    return summary

prev_summary = get_objects_summary(previous_frame.segmentation)
curr_summary = get_objects_summary(current_frame.segmentation)

changes = []
for h, info in curr_summary.items():
    if h in prev_summary:
        if info['center'] != prev_summary[h]['center']:
            changes.append(f"Object {h} moved from {prev_summary[h]['center']} to {info['center']}")
    else:
        changes.append(f"Object {h} appeared at {info['center']}")

for h, info in prev_summary.items():
    if h not in curr_summary:
        changes.append(f"Object {h} disappeared")

print("\n".join(changes) if changes else "No significant object changes")

seg = current_frame.segmentation
purple_disk_pos = None
white_star_pos = None
gray_star_pos = None
purple_ring_pos = None

for node in seg['nodes']:
    if node['color'] == 'p' and node['pixels'] > 10:
        boundary = node['boundary']
        purple_disk_pos = (sum(p[0] for p in boundary) // len(boundary), sum(p[1] for p in boundary) // len(boundary))
    elif node['color'] == 'W' and node['pixels'] > 5:
        boundary = node['boundary']
        white_star_pos = (sum(p[0] for p in boundary) // len(boundary), sum(p[1] for p in boundary) // len(boundary))
    elif node['color'] in ['g', 'G'] and node['pixels'] > 5 and node['hash'] != 'bf6a9cf9c2141748':
        boundary = node['boundary']
        gray_star_pos = (sum(p[0] for p in boundary) // len(boundary), sum(p[1] for p in boundary) // len(boundary))

ring_nodes = [node for node in seg['nodes'] if node['color'] == 'p' and node['pixels'] <= 5]
if ring_nodes:
    all_pts = []
    for node in ring_nodes:
        all_pts.extend(node['boundary'])
    purple_ring_pos = (sum(p[0] for p in all_pts) // len(all_pts), sum(p[1] for p in all_pts) // len(all_pts))

print(f"Purple Disk: {purple_disk_pos}")
print(f"White Star: {white_star_pos}")
print(f"Gray Star: {gray_star_pos}")
print(f"Purple Ring: {purple_ring_pos}")
