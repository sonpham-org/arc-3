def get_game_objects(segmentation):
    objects = []
    for node in segmentation['nodes']:
        center = (sum(p[0] for p in node['boundary']) // len(node['boundary']),
                   sum(p[1] for p in node['boundary']) // len(node['boundary']))
        objects.append({
            'id': node['id'],
            'hash': node['hash'],
            'color': node['color'],
            'pixels': node['pixels'],
            'center': center
        })
    
    # Filter out objects that are too close to the edges (HUD/background)
    # The board is 64x64.
    game_objs = [o for o in objects if 5 < o['center'][0] < 59 and 5 < o['center'][1] < 59]
    return game_objs

