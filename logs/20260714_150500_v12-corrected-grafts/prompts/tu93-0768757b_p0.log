# Build graph of valid moves based on gray blocks
# Player grid positions: 16, 22, 28, 34, 40, 46
player_positions = [16, 22, 28, 34, 40, 46]

# Get all gray blocks from current frame
seg = current_frame.segmentation
gray_blocks = []
for n in seg['nodes']:
    if n['color'] == 'g':
        b = n['boundary']
        center_r = sum(r for r,c in b) // len(b)
        center_c = sum(c for r,c in b) // len(b)
        if 16 <= center_r <= 46 and 16 <= center_c <= 46:
            gray_blocks.append((center_r, center_c))

print("Gray blocks:", gray_blocks)

# Build adjacency graph
# A gray block at (r, c) connects:
# - If r is player grid and c is not: horizontal between (r, c-3) and (r, c+3)
# - If c is player grid and r is not: vertical between (r-3, c) and (r+3, c)
graph = {}
for r, c in gray_blocks:
    if r in player_positions and c not in player_positions:
        # Horizontal block
