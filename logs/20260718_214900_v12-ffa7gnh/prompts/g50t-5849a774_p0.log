import collections

# Build passable grid from ASCII
lines = current_frame.ascii.split('\n')
rows, cols = 64, 64
# Passable: B, R, b (black, red, blue). Not passable: W, w, g, etc.
passable = set(['B', 'R', 'b'])

grid = []
for r in range(64):
    row = lines[r] if r < len(lines) else ''
    grid.append([row[c] if c < len(row) else ' ' for c in range(64)])

# Player center: [28, 52] (from segmentation)
# Goal center: [22, 28] (from segmentation)
# Player is 5x5, so top-left is [26, 50]
# Goal is 7x7, so top-left is [19, 25]

# For BFS, treat player as a point (center)
# Player center: (28, 52)
# Goal center: (22, 28)
# Player moves 6 units per action (5x5 square moves to next 5x5 position)

# Actually, the player moves 6 rows/cols per action (from [26,50] to [32,50] is DOWN)
# So the grid is effectively 6x6 cells, each 6x6 pixels

# Let me check: player at [26,50]-[30,54], DOWN to [32,50]-[36,54]
# That's a move of 6 rows down. So each action moves the player by 6 units.

# BFS on the grid with step size 6
start = (28, 52)  # player center
goal = (22, 28)   # goal center
step = 6

# Check if a 5x5 player at center (r, c) is valid
def is_valid(r, c):
    # Player occupies rows r-2 to r+2, cols c-2 to c+2
    for dr in range(-2, 3):
        for dc in range(-2, 3):
            pr, pc = r + dr, c + dc
            if pr < 0 or pr >= 64 or pc < 0 or pc >= 64:
                return False
            if grid[pr][pc] not in passable:
                return False
    return True

# BFS
queue = collections.deque([(start, [])])
visited = {start}
while queue:
    (r, c), path = queue.popleft()
    if (r, c) == goal:
        print(f"Path found: {path} ({len(path)} steps)")
        break
    for dr, dc, name in [(-6, 0, 'UP'), (6, 0, 'DOWN'), (0, -6, 'LEFT'), (0, 6, 'RIGHT')]:
        nr, nc = r + dr, c + dc
        if (nr, nc) not in visited and is_valid(nr, nc):
            visited.add((nr, nc))
            queue.append(((nr, nc), path + [name]))
else:
    print("No path found with step=6")
    
# Also try step=5 (maybe player moves by 5 units)
queue = collections.deque([(start, [])])
visited = {start}
found = False
while queue:
    (r, c), path = queue.popleft()
    if (r, c) == goal:
        print(f"Path found (step=5): {path} ({len(path)} steps)")
        found = True
        break
    for dr, dc, name in [(-5, 0, 'UP'), (5, 0, 'DOWN'), (0, -5, 'LEFT'), (0, 5, 'RIGHT')]:
        nr, nc = r + dr, c + dc
        if (nr, nc) not in visited and is_valid(nr, nc):
            visited.add((nr, nc))
            queue.append(((nr, nc), path + [name]))
if not found:
    print("No path found with step=5")
