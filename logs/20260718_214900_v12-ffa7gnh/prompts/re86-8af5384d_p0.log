# Let me compute optimal positions for collecting boxes with the diamond
# Diamond center at (48, 45), arm length ~12
# Boxes: (5,5), (5,44), (14,50), (20,20), (26,8), (29,47), (32,32), (38,20)

# For each pair of boxes, find if there's a position where both are within arm length
boxes = [(5,5), (5,44), (14,50), (20,20), (26,8), (29,47), (32,32), (38,20)]
arm_len = 12

def can_collect(center, box):
    r, c = center
    br, bc = box
    # Check if box is on D1 or D2 diagonal from center
    if (br + bc == r + c) or (br - bc == r - c):
        # Check distance (Chebyshev for diagonal)
        return max(abs(r - br), abs(c - bc)) <= arm_len
    return False

# Find positions that collect multiple boxes
from itertools import combinations

