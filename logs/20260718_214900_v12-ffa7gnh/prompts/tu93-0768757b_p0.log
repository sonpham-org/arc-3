cols = sorted(set(c for r, c in grid_cells.keys()))
for r in rows:
    row_str = ""
    for c in range(min(cols), max(cols) + 1):
        row_str += grid_cells.get((r, c), '.')
    print(f"  {r}: {row_str}")

