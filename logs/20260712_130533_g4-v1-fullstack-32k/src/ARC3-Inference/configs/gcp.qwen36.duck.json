{
  "shared": {
    "model_name": "Qwen/Qwen3.6-27B-FP8",
    "base_url": "http://127.0.0.1:1234/v1",
    "provider": "vllm",
    "context_window": 32768
  },
  "experiments": {
    "root_dir": "runs"
  },
  "environment": {
    "dataset": "",
    "include_tags": [
      "official"
    ],
    "exclude_tags": [],
    "games": [],
    "environments_dir": "/opt/arc3/environment_files",
    "max_steps": null,
    "max_runtime_minutes": 132,
    "max_experiment_runtime_minutes": null,
    "max_experiment_runtime_hours": null,
    "n_passes": 1,
    "concurrent_jobs": 25
  },
  "deployment": {
    "target": "inline",
    "wait": true,
    "source_repos": [
      "../tufa-arc-agi-framework"
    ],
    "slurm": {
      "gpu": "RTX",
      "gpu_count": 1,
      "time": "04:00:00",
      "image": "",
      "partition": "",
      "nodelist": "",
      "start_local_server": false,
      "extra_sbatch_flags": []
    }
  },
  "server": {
    "backend": "vllm",
    "install_target": "install-a108",
    "host": "127.0.0.1",
    "port": 1234,
    "tensor_parallel_size": 1,
    "dtype": "auto",
    "gpu_memory_utilization": 0.9,
    "trust_remote_code": true,
    "generation_config": "vllm",
    "language_model_only": false,
    "enable_prefix_caching": true,
    "tool_call_parser": "qwen3_coder",
    "reasoning_parser": "qwen3",
    "default_chat_template_kwargs": {
      "preserve_thinking": true
    },
    "extra_args": "--speculative-config '{\"method\":\"ngram\",\"num_speculative_tokens\":5,\"prompt_lookup_max\":5,\"prompt_lookup_min\":2}' --max-num-seqs 128",
    "download_allow_patterns": [
      "*.json",
      "*.jinja",
      "*.txt",
      "*.safetensors"
    ],
    "download_max_workers": 16
  },
  "analyzer": {
    "app_name": "ARC3 G4 Duck Harness",
    "max_output": 0,
    "thinking": true,
    "temperature": 0.6,
    "top_p": 0.95,
    "top_k": 20,
    "timeout": 900,
    "yield_seconds": 900,
    "tool_steps": 0,
    "tool_timeout": 30,
    "tool_output_tokens": 1024,
    "save_request_logs": true
  },
  "chat": {
    "max_tokens": 2048,
    "temperature": 0.7,
    "top_p": 0.8,
    "top_k": 20,
    "thinking": false
  },
  "viewer": {
    "port": 8021
  },
  "multimodal": {
    "context": "current_grid",
    "upscale": 8,
    "style": "outline"
  }
}