{
  "shared": {
    "model_name": "Qwen/Qwen3.6-27B",
    "base_url": "https://openrouter.ai/api/v1",
    "provider": "openrouter",
    "context_window": 65536
  },
  "experiments": {
    "root_dir": "/sw/public/arc_3_results/{username}"
  },
  "environment": {
    "dataset": "",
    "include_tags": ["official"],
    "exclude_tags": [],
    "games": [],
    "max_steps": null,
    "max_runtime_minutes": 90,
    "max_experiment_runtime_minutes": null,
    "max_experiment_runtime_hours": null,
    "n_passes": 5,
    "concurrent_jobs": 32
  },
  "deployment": {
    "target": "inline",
    "wait": false,
    "source_repos": ["../tufa-arc-agi-framework", "../re-arc-3"],
    "slurm": {
      "gpu": "B200",
      "gpu_count": 1,
      "time": "07:00:00",
      "image": "",
      "partition": "llm",
      "nodelist": "",
      "start_local_server": false,
      "extra_sbatch_flags": ["--account=llm", "--qos=llm"]
    }
  },
  "server": {
    "backend": "vllm",
    "host": "127.0.0.1",
    "port": 1234,
    "tensor_parallel_size": 1,
    "generation_config": "vllm",
    "language_model_only": false,
    "enable_prefix_caching": true,
    "tool_call_parser": "qwen3_coder",
    "reasoning_parser": "qwen3",
    "default_chat_template_kwargs": {
      "preserve_thinking": true
    }
  },
  "analyzer": {
    "app_name": "ARC3 Agent Harness",
    "max_output": 0,
    "thinking": true,
    "temperature": 0.6,
    "top_p": 0.95,
    "top_k": 20,
    "timeout": 120,
    "tool_steps": 0,
    "tool_timeout": 30,
    "tool_output_tokens": 1024,
    "save_request_logs": false
  },
  "chat": {
    "max_tokens": 2048,
    "temperature": 0.7,
    "top_p": 0.8,
    "top_k": 20,
    "thinking": true
  },
  "viewer": {
    "port": 8024
  },
  "multimodal" : {
    "context" : "current_grid",
    "upscale" : 16
  }
}
