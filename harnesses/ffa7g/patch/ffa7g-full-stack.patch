+    for r in range(nrows):
+        for c in range(ncols):
+            seen_vals = set()
+            for g in grids:
+                seen_vals.add(g[r][c] if r < len(g) and c < len(g[r]) else None)
+                if len(seen_vals) > 1:
+                    active.add((r, c))
+                    break
