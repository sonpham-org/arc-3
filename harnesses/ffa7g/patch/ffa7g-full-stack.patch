+def _animated_objects(grids, gap: int = 1) -> list[dict[str, Any]]:
+    """Separate an animation into distinct 'animated objects'. A cell is animated if
+    its value varies across the frames; animated cells that touch (8-connected, with
+    `gap` cells of slack for a shape moving a small step) are one object. Returns a
+    list of {pos:[row,col], size:[rows,cols], cells:int, _cells:frozenset}, largest
+    first -- so two things animating at once (e.g. a growing box and a blinking light)
+    each get their own tight bounding box instead of one huge merged one."""
+    if not grids:
+        return []
+    nrows = max(len(g) for g in grids)
+    ncols = max((len(g[0]) if g else 0) for g in grids)
