+    (r, c)) when given, else the full grid."""
+    if cells is not None:
+        n = 0
+        for r, c in cells:
+            av = a[r][c] if r < len(a) and c < len(a[r]) else None
+            bv = b[r][c] if r < len(b) and c < len(b[r]) else None
+            if av != bv:
