+            "pos": [min(rs), min(cs)],
+            "size": [max(rs) - min(rs) + 1, max(cs) - min(cs) + 1],
+            "cells": len(comp),
+            "_cells": frozenset(comp),
+        })
+    objects.sort(key=lambda o: (-o["cells"], o["pos"]))
+    return objects
+
+
+def _changed_axes(a, b, band_rows, band_cols, model_bar=None):
+    """Rows and cols that differ between grids a and b, plus whether any differing cell lies
+    OUTSIDE the housekeeping mask. The mask is the band (band_rows/band_cols) UNION the model's
+    predicted bar cells (`model_bar`, a set of (r, c) or None). Single pass over the grid."""
+    changed_rows: set[int] = set()
+    changed_cols: set[int] = set()
+    outside = False
+    n = max(len(a), len(b))
+    for r in range(n):
+        ar = a[r] if r < len(a) else ()
+        br = b[r] if r < len(b) else ()
+        m = max(len(ar), len(br))
+        for c in range(m):
+            if (ar[c] if c < len(ar) else None) != (br[c] if c < len(br) else None):
+                changed_rows.add(r)
+                changed_cols.add(c)
+                if (r not in band_rows and c not in band_cols
+                        and (model_bar is None or (r, c) not in model_bar)):
+                    outside = True
+    return changed_rows, changed_cols, outside
+
+
+def _band_desc(rows, cols):
+    parts = []
+    if rows:
+        parts.append(f"rows {min(rows)}-{max(rows)}")
+    if cols:
+        parts.append(f"cols {min(cols)}-{max(cols)}")
+    return ", ".join(parts) or None
+
+
+class _HousekeepingBand:
+    """Learns the deterministic 'housekeeping' band -- a HUD moves/timer bar or edge strip --
+    online, per level. A bar is invisible to per-CELL change frequency (each cell changes once
+    as the frontier passes) but at the ROW/COL level its rows (or cols) change on nearly every
+    action; so a row/col that changed on >= `threshold` of a rolling window of the last
+    `window` actions is housekeeping. Reset on level change (the bar may move). An empty band
+    means no HUD, so a no-impact action is simply an unchanged board."""
+
+    def __init__(self, window: int = 20, threshold: float = 0.9, warmup: int = 8):
+        self.window = window
+        self.threshold = threshold
+        self.warmup = warmup
+        self._hist: list[tuple[set[int], set[int]]] = []
+
+    def reset(self) -> None:
+        self._hist = []
+
+    def band(self) -> tuple[set[int], set[int]]:
+        n = len(self._hist)
+        if n < self.warmup:
+            return set(), set()
+        rc: dict[int, int] = {}
+        cc: dict[int, int] = {}
+        for rows, cols in self._hist:
+            for r in rows:
+                rc[r] = rc.get(r, 0) + 1
+            for c in cols:
+                cc[c] = cc.get(c, 0) + 1
+        thr = self.threshold * n
+        return ({r for r, k in rc.items() if k >= thr}, {c for c, k in cc.items() if k >= thr})
+
+    def observe(self, changed_rows: set[int], changed_cols: set[int]) -> None:
+        self._hist.append((set(changed_rows), set(changed_cols)))
+        if len(self._hist) > self.window:
+            self._hist.pop(0)
+
+
+_ARC_COLOR_CHARS = "WwgGcBMPRbSYOrNp"
+
+
+def _grid_to_rows(grid):
+    """int grid -> list of letter-coded row strings (the `frame` format advance_hud sees)."""
+    return ["".join(_ARC_COLOR_CHARS[max(0, min(15, int(v)))] for v in row) for row in grid]
+
+
+def _verify_hud_model(prev_rows, actual_rows, pred_rows):
+    """prev/actual/pred are letter-row lists. Returns (model_ok, bar_cells): bar_cells = the cells
+    the model changed vs prev (its claimed housekeeping); model_ok = the real board matches the
+    prediction on every one of them. The caller unions bar_cells into the housekeeping mask (it
+    never subtracts, so a partial model can't cause a false no-impact miss)."""
+    model_ok = True
+    bar_cells = set()
+    n = max(len(prev_rows), len(actual_rows), len(pred_rows))
+    for r in range(n):
+        p = prev_rows[r] if r < len(prev_rows) else ""
+        a = actual_rows[r] if r < len(actual_rows) else ""
+        d = pred_rows[r] if r < len(pred_rows) else ""
+        m = max(len(p), len(a), len(d))
+        for c in range(m):
+            pc = p[c] if c < len(p) else None
+            ac = a[c] if c < len(a) else None
+            dc = d[c] if c < len(d) else None
+            if dc != pc:              # model claims the bar changes this cell
+                bar_cells.add((r, c))
+                if ac != dc:
+                    model_ok = False
+    return model_ok, bar_cells
+
+
+class _HudCodeModel:
+    """An LLM-authored `advance_hud(frame, action) -> frame` predictor, verified by replay.
+    `frame` and the return are newline-joined letter grids (same as current_frame.ascii). While
+    its bar prediction keeps matching reality it drives no-impact detection; a misprediction
+    marks it stale (the agent is asked to rewrite); after MAX_FAILS it is dropped and the caller
+    falls back to the statistical band. Runs under a hard wall-clock cap so a bad model can't
+    hang the run."""
+
+    MAX_FAILS = 2
+    SAFE_BUILTINS = ("range", "len", "min", "max", "abs", "enumerate", "list", "tuple", "str",
+                     "int", "float", "bool", "zip", "sorted", "any", "all", "sum", "map",
+                     "filter", "reversed", "set", "dict", "ord", "chr", "isinstance")
+
+    def __init__(self):
+        self.source = None
+        self.fn = None
+        self.fails = 0
+        self.stale = False
+        self.error = None
+
+    @property
+    def active(self):
+        return self.fn is not None and not self.stale
+
+    def register(self, code):
+        code = str(code or "").strip()
+        if code.startswith("```"):                       # tolerate a fenced block
+            code = code.split("\n", 1)[-1].rsplit("```", 1)[0]
+        if code == self.source and self.fn is not None:
+            return None                                  # unchanged -> keep validity state
+        import builtins as _b
+        ns = {"__builtins__": {k: getattr(_b, k) for k in self.SAFE_BUILTINS if hasattr(_b, k)}}
+        try:
+            exec(code, ns)
+        except Exception as exc:
+            self.error = f"{type(exc).__name__}: {exc}"
+            return self.error
+        fn = ns.get("advance_hud")
+        if not callable(fn):
+            self.error = "code must define advance_hud(frame, action)"
+            return self.error
+        self.source, self.fn, self.fails, self.stale, self.error = code, fn, 0, False, None
+        return None
+
+    def predict(self, frame_ascii, action_display, timeout=0.75):
+        if self.fn is None:
+            return None
+        import signal
+        armed = old = None
+        try:
+            def _to(signum, frame):
+                raise TimeoutError("advance_hud timed out")
+            old = signal.signal(signal.SIGALRM, _to)
+            signal.setitimer(signal.ITIMER_REAL, timeout)
+            armed = True
+        except (ValueError, AttributeError, OSError):
+            armed = False                                # not main thread: run uncapped
+        try:
+            out = self.fn(frame_ascii, action_display)
+            return out if isinstance(out, str) else None
+        except Exception:
+            return None
+        finally:
+            if armed:
+                signal.setitimer(signal.ITIMER_REAL, 0)
+                signal.signal(signal.SIGALRM, old)
+
+    def record(self, model_ok):
+        if model_ok:
+            self.fails = 0
+        else:
+            self.fails += 1
+            if self.fails >= self.MAX_FAILS:
+                self.stale = True
+
+
+class _StateGraph:
+    """Per-level graph of CANONICAL game states (HUD/housekeeping excluded) and the actions
+    between them. Nodes = canonical boards; edges = (state, action_display) -> next_state.
+
+    The canonical key masks the deterministic HUD/edge band (band rows/cols) and any verified
+    `advance_hud` bar cells with an out-of-band sentinel char (`.`, not in the 16-colour palette,
+    so it never collides with a real colour -- masking to colour 0 WOULD collide). The mask is the
+    MONOTONIC union of all housekeeping seen this level; when it grows, every stored node/edge is
+    re-canonicalised (masked cells only increase, so keys can only merge). Reset per level.
+    """
+
+    MASK = "."
+
+    def __init__(self):
+        self.reset()
+
+    def reset(self):
+        self.nodes = {}                 # key -> {grid, node_id, first_seen_step, last_seen_step, visit_count, self_loop_count}
+        self.id_of = {}                 # key -> int id
+        self.key_of = {}                # int id -> key
+        self.next_id = 0
+        self.edges = {}                 # src_key -> {action_display -> {dst_key: count}}
+        self.current_key = None
+        self.mask_rows = set()
+        self.mask_cols = set()
+        self.mask_cells = set()
+
+    def canonical(self, grid):
+        rows = _grid_to_rows(grid)
+        mr, mc, mcells = self.mask_rows, self.mask_cols, self.mask_cells
+        out = []
+        for r, row in enumerate(rows):
+            if r in mr:
+                out.append(self.MASK * len(row))
+            elif mc or mcells:
+                out.append("".join(self.MASK if (c in mc or (r, c) in mcells) else ch
+                                   for c, ch in enumerate(row)))
+            else:
+                out.append(row)
+        return "\n".join(out)
+
+    def set_mask(self, band_rows, band_cols, model_bar):
+        """Canonical mask = the CURRENT rolling housekeeping band (rows/cols) UNION verified
+        `advance_hud` cells (kept monotonically -- those are exact). Deliberately NOT a monotonic
+        union of the band: that permanently masks TRANSIENT over-flags (e.g. a briefly-animating
+        element the band flags for a few actions), which coarsens the graph and risks false
+        revisits. With the rolling band, when the mask shrinks, re-canonicalisation makes those
+        states distinct again -- a MISSED revisit (safe) rather than an over-masked false one."""
+        new_cells = self.mask_cells | set(model_bar or ())
+        new_mr, new_mc = set(band_rows), set(band_cols)
+        if new_mr != self.mask_rows or new_mc != self.mask_cols or new_cells != self.mask_cells:
+            self.mask_rows, self.mask_cols, self.mask_cells = new_mr, new_mc, new_cells
+            if self.nodes:
+                self._recanonicalize()
+
+    def _recanonicalize(self):
+        old_nodes, old_edges, old_current = self.nodes, self.edges, self.current_key
+        self.nodes, self.edges, self.id_of, self.key_of = {}, {}, {}, {}
+        remap = {}
+        for old_key, node in old_nodes.items():
+            nk = self.canonical(node["grid"])
+            remap[old_key] = nk
+            ex = self.nodes.get(nk)
+            if ex is None:
+                self.nodes[nk] = node
+            else:  # two old states collapse into one under the wider mask -> merge
+                ex["visit_count"] += node["visit_count"]
+                ex["self_loop_count"] += node["self_loop_count"]
+                ex["first_seen_step"] = min(ex["first_seen_step"], node["first_seen_step"])
+                ex["last_seen_step"] = max(ex["last_seen_step"], node["last_seen_step"])
+                ex["node_id"] = min(ex["node_id"], node["node_id"])  # lowest id survives
+        for nk, node in self.nodes.items():
+            self.id_of[nk] = node["node_id"]
+            self.key_of[node["node_id"]] = nk
+        for src, amap in old_edges.items():
+            ns = remap[src]
+            for action, dmap in amap.items():
+                for dst, cnt in dmap.items():
+                    nd = remap[dst]
+                    d = self.edges.setdefault(ns, {}).setdefault(action, {})
+                    d[nd] = d.get(nd, 0) + cnt
+        self.current_key = remap.get(old_current) if old_current is not None else None
+
+    def plan_terminal_if_all_known(self, action_sequence):
+        """If EVERY action in the sequence follows a KNOWN deterministic edge from the current node
+        (single recorded destination), return the node id the plan ends at -- the whole plan stays
+        in already-explored territory and reaches no new (state, action), so it is pure re-treading.
+        Return None as soon as an action is untried or non-deterministic (the plan reaches new ground
+        there -> allowed). Self-loops are not stored as edges, so a self-loop action returns None here
+        and is caught per-action by the no_impact stop instead."""
+        cur = self.current_key
+        if cur is None or not action_sequence:
+            return None
+        for act in action_sequence:
+            dmap = self.edges.get(cur, {}).get(act)
+            if not dmap or len(dmap) != 1:
+                return None
+            cur = next(iter(dmap))
+        return self.id_of.get(cur)
+
+    def tried_actions(self, node_id):
+        """Action labels already tried from a node -> the agent computes the frontier as
+        valid_actions minus these (an unexplored (state, action) is where exploration should aim)."""
+        key = self.key_of.get(node_id)
+        return sorted((self.edges.get(key) or {}).keys()) if key is not None else []
+
+    def observe(self, new_grid, action_display, step, band_rows, band_cols, model_bar):
+        self.set_mask(band_rows, band_cols, model_bar)
+        prev_key = self.current_key
+        new_key = self.canonical(new_grid)
+        seen_before = new_key in self.nodes
+        self_loop = prev_key is not None and new_key == prev_key
+        if not seen_before:
+            nid = self.next_id
+            self.next_id += 1
+            self.nodes[new_key] = {"grid": new_grid, "node_id": nid, "first_seen_step": step,
+                                   "last_seen_step": step, "visit_count": 1, "self_loop_count": 0}
+            self.id_of[new_key] = nid
+            self.key_of[nid] = new_key
+        else:
+            n = self.nodes[new_key]
+            n["visit_count"] += 1
+            n["last_seen_step"] = step
+        nondeterministic = False
+        if prev_key is not None and not self_loop:
+            dmap = self.edges.setdefault(prev_key, {}).setdefault(action_display, {})
+            if dmap and new_key not in dmap:
+                nondeterministic = True  # this (state,action) previously led elsewhere
+            dmap[new_key] = dmap.get(new_key, 0) + 1
+        elif self_loop:
+            self.nodes[prev_key]["self_loop_count"] += 1
+        self.current_key = new_key
+        return {
+            "is_new_state": not seen_before,
+            "self_loop": self_loop,
+            "revisited_state": seen_before and not self_loop,
+            "nondeterministic_edge": nondeterministic,
+            "state_node_id": self.id_of[new_key],
+            "graph_nodes": len(self.nodes),
+        }
+
+    def node_grid(self, ref):
+        key = ref if isinstance(ref, str) else self.key_of.get(ref)
+        node = self.nodes.get(key)
+        return node["grid"] if node else None
+
+    def light_view(self, cap=200):
+        """Compact, grid-free view shipped to the sandbox each turn: ids, per-node stats, edges."""
+        keep = sorted(self.nodes.values(), key=lambda n: n["last_seen_step"], reverse=True)[:cap]
+        keep_ids = {n["node_id"] for n in keep}
+        nodes = {n["node_id"]: [n["first_seen_step"], n["visit_count"], n["self_loop_count"]]
+                 for n in keep}
+        edges = []
+        for src, amap in self.edges.items():
+            sid = self.id_of.get(src)
+            if sid not in keep_ids:
+                continue
+            for action, dmap in amap.items():
+                for dst in dmap:
+                    did = self.id_of.get(dst)
+                    if did in keep_ids:
+                        edges.append([sid, did, action])
+        return {"current": self.id_of.get(self.current_key), "nodes": nodes,
+                "edges": edges, "truncated": len(self.nodes) > cap}
+
+
+def _reexplore_strict() -> bool:
+    """A/B toggle: with ARC3_REEXPLORE_STRICT set, `intent='re-explore'` hard-stops the batch the
+    moment an action fails to reach a NEW state; otherwise (soft, default) it only flags an
+    unproductive batch afterwards."""
+    return os.environ.get("ARC3_REEXPLORE_STRICT", "").strip().lower() in {"1", "true", "yes"}
+
+
+def _animation_summary(new_state, previous_grid, board_changed) -> dict[str, Any]:
+    """Compact metadata about the intermediate animation frames, added to every action
+    result so the model always sees it -- no opt-in. `animation_only_changed` flags an
+    action that flashed a real transient change but left the same final board. The
+    nested `animation` dict carries the per-action detail (per-frame change magnitudes
+    with hold-frames dropped, plus each separated animated object) that step_env folds
+    into `executed_actions`; `show_animation(...)` renders those objects."""
+    frames = list(getattr(new_state, "all_frames", ()) or ())
+    grids = [g for g in (_grid_from_frame(f) for f in frames) if g]
+    changed: set[tuple[int, int]] = set()
+    for g in grids:
+        for r in range(max(len(previous_grid), len(g))):
+            pr = previous_grid[r] if r < len(previous_grid) else ()
+            gr = g[r] if r < len(g) else ()
+            for c in range(max(len(pr), len(gr))):
+                pv = pr[c] if c < len(pr) else None
+                gv = gr[c] if c < len(gr) else None
+                if pv != gv:
+                    changed.add((r, c))
+    if changed:
+        rows = [x[0] for x in changed]
+        cols = [x[1] for x in changed]
+        bbox = [min(rows), min(cols), max(rows), max(cols)]
+    else:
+        bbox = None
+    # Per-frame change magnitude over [pre-action, f0, f1, ...]; 0 == a hold/dwell frame
+    # (kept -- a run of 0s tells the agent how long a state was held).
+    seq = [previous_grid, *grids]
+    per_frame = [_grid_diff_count(seq[i], seq[i + 1]) for i in range(len(seq) - 1)]
+    objects = []
+    for obj in _animated_objects(grids):
+        obj_per_frame = [_grid_diff_count(seq[i], seq[i + 1], obj["_cells"]) for i in range(len(seq) - 1)]
+        objects.append(
+            f"top-left ({obj['pos'][0]},{obj['pos'][1]}) {obj['size'][0]}x{obj['size'][1]},"
+            f" {obj['cells']} cells, per-frame {obj_per_frame}"
+        )
+    # Compact, self-describing per-action animation record: scalars + one string per
+    # animated object. The per-frame lists are stringified so the result renderer keeps
+    # each on one line. The flat animation_* keys below stay in the payload (the viewer
+    # reads them) but are dropped from the model-facing compact result -- it all lives here.
+    animation = {
+        "num_frames": len(frames),
+        "changed": bool(changed),
+        "only_changed": bool(changed and not board_changed),
+        "total_cells_changed": len(changed),
+        "cells_changed_per_frame": str(per_frame),
+        "objects": objects,
+    }
+    return {
+        "animation_frame_count": len(frames),
+        "animation_changed": bool(changed),
+        "animation_only_changed": bool(changed and not board_changed),
+        "animation_changed_cell_count": len(changed),
+        "animation_changed_bbox": bbox,
+        "animation_transition_count": sum(1 for n in per_frame if n),
+        "animation": animation,
+    }
+
