+def load_last_animation(path: Path) -> tuple[int, list[tuple[str, list[Frame]]]]:
+    """(total_actions, [(action, ordered frames incl. final)]) of the most recent
+    action(...) call -- one entry PER INDIVIDUAL ACTION, in execution order."""
+    if not path.exists():
+        return 0, []
+    try:
+        payload = json.loads(path.read_text(encoding="utf-8"))
+    except (OSError, json.JSONDecodeError):
+        return 0, []
+    raw = payload.get("last_animation")
+    if not isinstance(raw, dict):
+        return 0, []
+    entries: list[tuple[str, list[Frame]]] = []
+    for item in raw.get("entries", []):
+        if not isinstance(item, dict):
+            continue
+        frames = [frame_from_payload(p) for p in item.get("frames", [])]
+        entries.append((str(item.get("action", "")), [f for f in frames if f is not None]))
+    try:
+        total = int(raw.get("total_actions", len(entries)))
+    except (TypeError, ValueError):
+        total = len(entries)
+    return total, entries
+
